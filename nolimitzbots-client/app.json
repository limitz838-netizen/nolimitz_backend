{
  "expo": {
    "name": "NolimitzBots",
    "slug": "nolimitzbots-client",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#050B18"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.nolimitzbots.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/icon.png",
        "backgroundColor": "#050B18"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/icon.png"
    },
    "extra": {
      "eas": {
        "projectId": "5a898a7e-50af-409c-995b-9aa9329736d6"
      }
    },
    "plugins": [
      "expo-font"
    ]
  }
}
